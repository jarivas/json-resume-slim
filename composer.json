{
    "name": "jarivas/json-resume-slim",
    "description": "A JSON Resume API built with Slim Framework",
    "type": "project",
    "version": "1.0.0",
    "require": {
        "slim/slim": "4.*",
        "justinrainbow/json-schema": "^6.7",
        "jarivas/sql-models": "^1.8",
        "jarivas/php-env": "^1.0",
        "robinvdvleuten/ulid": "^5.0",
        "jarivas/php-popo-models": "^1.3",
        "psr/log": "^3.0",
        "jarivas/http-client": "^1.4",
        "nyholm/psr7": "^1.8",
        "nyholm/psr7-server": "^1.1"
    },
    "autoload": {
        "psr-4": {
            "App\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Tests\\": "tests/"
        }
    },
    "require-dev": {
        "phpunit/phpunit": "^13.0",
        "phpmd/phpmd": "^2.15",
        "phpstan/phpstan": "^2.1",
        "squizlabs/php_codesniffer": "^4.0",
        "symfony/var-dumper": "^8.0"
    }
}
